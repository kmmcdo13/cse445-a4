//tells the system this is an xml file and uses utf-8 encoding
<?xml version="1.0" encoding="utf-8"?>

//defines the schema
//the default xmlns and namespace must match the xml file namespace
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main"
  targetNamespace="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main"
  elementFormDefault="qualified" attributeFormDefault="unqualified">

  //root element of the xml document
  //everything in the xml file must be inside nationalparks
  <xs:element name="NationalParks">
    <xs:complexType>

      //elements must appear in this exact order (left to right)
      <xs:sequence>

        //represents each park entry
        //unbounded allows as many parks as needed (assignment requires 10+)
        <xs:element name="NationalPark" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>

              //min=1 and max=1 prevents missing names or duplicate name elements (each park must have exactly one name)
              <xs:element name="Name" type="xs:string" minOccurs="1" maxOccurs="1"/>

              //max=unbounded allows multiple phone numbers for the same park (each park must have at least one phone number )
              <xs:element name="Phone" type="xs:string" minOccurs="1" maxOccurs="unbounded"/>

              //groups address information together
              <xs:element name="Address">
                <xs:complexType>
                  <xs:sequence>

                    //street number part of the address
                    <xs:element name="Number" type="xs:string"/>

                    //street name
                    <xs:element name="Street" type="xs:string"/>

                    //city location
                    <xs:element name="City" type="xs:string"/>

                    //state abbreviation (i.e. AZ, CA, UT, etc.)
                    <xs:element name="State" type="xs:string"/>

                    //zip code
                    <xs:element name="Zip" type="xs:string"/>
                  </xs:sequence>

                  //nearest airport is required, else validation will fail 
                  <xs:attribute name="NearestAirport" type="xs:string" use="required"/>
                </xs:complexType>
              </xs:element>
            </xs:sequence>

            //rating is optiional (some parks have it while others do not)
            //xs:decimal ensures the value must be a number like "4.8" instead of text
            <xs:attribute name="Rating" type="xs:decimal" use="optional"/>
          </xs:complexType>
        </xs:element>

      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema>
