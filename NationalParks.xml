<?xml version="1.0" encoding="utf-8"?>

<NationalParks
  <!-- sets the main namespace for the xml file, must match the schema namespace -->
  xmlns="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main"

  <!-- adds the xml schema instance namespace -->
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

  <!-- links xml file to xsd file -->
  xsi:schemaLocation="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main/NationalParks.xsd">

  <!-- first national park -->
  <NationalPark Rating="4.9">

    <!-- stores the name of the park -->
    <Name>Grand Canyon</Name>

    <!-- multiple phone elements -->
    <Phone>928-638-7496</Phone>
    <Phone>888-297-2757</Phone>

    <!-- address info -->
    <Address NearestAirport="Flagstaff">
      <Number>8</Number>
      <Street>S Entrance Road</Street>
      <City>Grand Canyon</City>
      <State>AZ</State>
      <Zip>86023</Zip>
    </Address>

  </NationalPark>

</NationalParks>
