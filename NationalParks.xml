<?xml version="1.0" encoding="utf-8"?>

<NationalParks
  <!-- sets the main namespace for the xml file, must match the schema namespace -->
  xmlns="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main"

  <!-- adds the xml schema instance namespace (needed so schemalocation can be used) -->
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

  <!-- links xml file to xsd file -->
  <!-- first url is the namespace and second url is the schema file location -->
  xsi:schemaLocation="https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main https://raw.githubusercontent.com/kmmcdo13/cse445-a4/main/NationalParks.xsd">

  <!-- first national park -->
  <NationalPark Rating="4.9">
    <!-- stores the name of the park -->
    <Name>Grand Canyon</Name>

    <!-- multiple phone elements, parks can have more than one contact number -->
    <Phone>928-638-7496</Phone>
    <Phone>888-297-2757</Phone>
    <Phone>866-499-2574</Phone>

    <!-- address groups all location information into one section -->
    <!-- nearestairport is included as an attribute on the address element -->
    <Address NearestAirport="Flagstaff">
      <!-- street number -->
      <Number>8</Number>
      <!-- street name -->
      <Street>S Entrance Road</Street>
      <!-- city name -->
      <City>Grand Canyon</City>
      <!-- state abbreviation -->
      <State>AZ</State>
      <!-- zip code -->
      <Zip>86023</Zip>
    </Address>
  </NationalPark>

